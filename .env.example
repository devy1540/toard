# ── Org (ADR-008) ──
ORG_TIMEZONE=UTC                         # 일별 집계의 "하루" 경계 (IANA, 예: Asia/Seoul). 기본 UTC

# ── Storage (ADR-003) ──
STORAGE_BACKEND=postgres                 # 'postgres'(기본) | 'clickhouse'
DATABASE_URL=postgres://toard:toard@localhost:5432/toard
CLICKHOUSE_URL=                          # CH 모드일 때만 (기본 http://localhost:8123)
CLICKHOUSE_USER=toard
CLICKHOUSE_PASSWORD=toard
CLICKHOUSE_DB=toard

# ── Auth.js (ADR-007) ──
AUTH_MODE=oauth                          # oauth(기본) | open(인증 없음·내부망 전제)
AUTH_OPEN_USER_EMAIL=                    # open 모드에서 귀속할 user (미지정 시 첫 user)
AUTH_CREDENTIALS_ENABLED=true            # id/pw 로그인·가입 활성 (false 로 OAuth 전용)
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
ALLOWED_EMAIL_DOMAINS=example.com         # (선택) OAuth·id/pw 공통 가입 허용 도메인
# 최초 관리자: 기본은 첫 실행 시 /setup 페이지에서 직접 생성. 아래는 headless 사전 프로비저닝 대안(선택).
BOOTSTRAP_ADMIN_EMAIL=                   # 설정 시 seed 가 admin 선생성 → /setup 잠김
BOOTSTRAP_ADMIN_PASSWORD=                # admin id/pw 로그인 비번 — seed 가 해시 저장
# OAuth provider — 자격 설정 시 해당 provider 활성화 (미설정 dev 는 첫-user 폴백)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Ingest (ADR-001) ──
# shim의 OTEL_EXPORTER_OTLP_ENDPOINT 가 가리킬 base URL (SDK가 /v1/logs append)
INGEST_BASE_URL=http://localhost:3000/api
# 온보딩 페이지(/onboarding)가 설치 스니펫에 넣을 공개 URL. 미설정 시 요청 host 로 자동 유추.
# 프록시 뒤나 브라우징 URL != 수집 URL 인 경우에만 지정 (예: https://toard.corp.com)
TOARD_PUBLIC_URL=

# ── Prompt content (opt-in, at-rest 봉투 암호화) ──
# 프롬프트/응답 본문을 저장할 때만 필요. DB 에는 암호문만, KEK 는 여기(앱 밖)에만 둔다.
# 생성: openssl rand -base64 32   |   미설정이면 본문 암호화 경로가 즉시 실패(조용히 평문 저장 안 함)
TOARD_CONTENT_KEK_B64=
# 설치 시 본문 수집 기본값. 미설정/off = per-user opt-in(사용자가 설치 시 선택).
# on = opt-out(KEK 있을 때 install.sh·설정 토글이 기본 켜짐, 사용자는 TOARD_SHIM_COLLECT_CONTENT=0 로 끔).
# 본문은 본인 전용(RLS)이라 운영자가 "history 기본 제공" 성격으로 opt-out 선택 가능.
CONTENT_COLLECTION_DEFAULT=

# ── Pricing (ADR-004) ──
LITELLM_PRICING_URL=https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json
MODELS_DEV_PRICING_URL=https://models.dev/api.json

# ── Cron ──
CRON_SECRET=                             # 설정 시 cron 엔드포인트(예: /api/cron/recompute) Bearer 인증
