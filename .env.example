# ── Storage (ADR-003) ──
STORAGE_BACKEND=postgres                 # 'postgres'(기본) | 'clickhouse'
DATABASE_URL=postgres://toard:toard@localhost:5432/toard
CLICKHOUSE_URL=                          # CH 모드일 때만

# ── Auth.js (ADR-007) ──
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
ALLOWED_EMAIL_DOMAINS=day1company.co.kr
BOOTSTRAP_ADMIN_EMAIL=                   # 최초 admin 부트스트랩

# ── Ingest (ADR-001) ──
# shim의 OTEL_EXPORTER_OTLP_ENDPOINT 가 가리킬 base URL (SDK가 /v1/logs append)
INGEST_BASE_URL=http://localhost:3000/api

# ── Pricing (ADR-004) ──
LITELLM_PRICING_URL=https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json
MODELS_DEV_PRICING_URL=https://models.dev/api.json
