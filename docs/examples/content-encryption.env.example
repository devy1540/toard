# toard managed content encryption Compose example
#
# 한 번에 provider 블록 하나만 선택해 주석을 해제하세요. provider 전환 때만
# 기존 provider를 active, 새 provider를 migration으로 동시에 설정합니다.
# secret/token/base64 원문은 env에 넣지 말고 ./secrets 아래 read-only 파일 또는
# 클라우드 workload identity를 사용하세요. 이 디렉터리는 Docker build context에서 제외됩니다.
TOARD_KEY_SECRET_DIR=./secrets
TOARD_USER_KEY_CACHE_TTL_SECONDS=1800

# 선택 비용 override — 두 값을 0 이상 유한 소수로 반드시 함께 설정합니다.
# 현재 active provider 한 개의 추정치에만 적용됩니다. Azure/Vault/OpenBao/local은
# 내장 단가가 없으므로 관리자 화면에 비용 추정이 필요할 때 이 쌍을 설정하세요.
# TOARD_KEY_COST_PER_10000_USD=0.04
# TOARD_KEY_MONTHLY_KEY_COST_USD=1.25

# AWS KMS — SDK default chain. Compose 호스트가 web identity를 제공하는 환경에서 사용합니다.
# TOARD_KEY_ACTIVE_PROVIDER=aws-kms
# TOARD_KEY_ACTIVE_AWS_KEY_ARN=arn:aws:kms:ap-northeast-2:123456789012:key/00000000-0000-0000-0000-000000000000
# TOARD_KEY_ACTIVE_AWS_REGION=ap-northeast-2
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/toard-kms
# AWS_WEB_IDENTITY_TOKEN_FILE=/run/toard-secrets/aws-web-identity-token
# AWS_ROLE_SESSION_NAME=toard
# TOARD_KEY_MIGRATION_PROVIDER=aws-kms
# TOARD_KEY_MIGRATION_AWS_KEY_ARN=arn:aws:kms:ap-northeast-2:123456789012:key/11111111-1111-1111-1111-111111111111
# TOARD_KEY_MIGRATION_AWS_REGION=ap-northeast-2

# GCP Cloud KMS — ADC workload identity 또는 read-only ADC JSON 파일 경로만 사용합니다.
# TOARD_KEY_ACTIVE_PROVIDER=gcp-kms
# TOARD_KEY_ACTIVE_GCP_KEY_NAME=projects/example/locations/asia-northeast3/keyRings/toard/cryptoKeys/user-keys-active
# GOOGLE_APPLICATION_CREDENTIALS=/run/toard-secrets/gcp-application-default-credentials.json
# TOARD_KEY_MIGRATION_PROVIDER=gcp-kms
# TOARD_KEY_MIGRATION_GCP_KEY_NAME=projects/example/locations/asia-northeast3/keyRings/toard/cryptoKeys/user-keys-next

# Azure Key Vault — production 기본은 managed identity입니다. 사용자 할당 identity면 client ID를 지정합니다.
# TOARD_KEY_ACTIVE_PROVIDER=azure-key-vault
# TOARD_KEY_ACTIVE_AZURE_KEY_ID=https://example.vault.azure.net/keys/toard-active/00000000000000000000000000000000
# TOARD_KEY_ACTIVE_AZURE_CREDENTIAL_MODE=managed-identity
# TOARD_KEY_ACTIVE_AZURE_MANAGED_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
# TOARD_KEY_MIGRATION_PROVIDER=azure-key-vault
# TOARD_KEY_MIGRATION_AZURE_KEY_ID=https://example.vault.azure.net/keys/toard-next/11111111111111111111111111111111
# TOARD_KEY_MIGRATION_AZURE_CREDENTIAL_MODE=managed-identity
# TOARD_KEY_MIGRATION_AZURE_MANAGED_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Azure workload identity 대안. managed-identity mode 두 줄을 아래 mode로 교체하고,
# 세 identity 값을 모두 설정합니다. token은 파일로만 전달합니다.
# TOARD_KEY_ACTIVE_AZURE_CREDENTIAL_MODE=workload-identity
# TOARD_KEY_MIGRATION_AZURE_CREDENTIAL_MODE=workload-identity
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# AZURE_TENANT_ID=11111111-1111-1111-1111-111111111111
# AZURE_FEDERATED_TOKEN_FILE=/run/toard-secrets/azure-federated-token

# HashiCorp Vault Transit — 아래 token file은 static credential이므로 최소 권한·짧은 수명·주기 회전이 필요합니다.
# TOARD_KEY_ACTIVE_PROVIDER=vault-transit
# TOARD_KEY_ACTIVE_TRANSIT_ADDRESS=https://vault.example.com:8200
# TOARD_KEY_ACTIVE_TRANSIT_MOUNT=transit
# TOARD_KEY_ACTIVE_TRANSIT_KEY_NAME=toard-active
# TOARD_KEY_ACTIVE_TRANSIT_AUTH_METHOD=token-file
# TOARD_KEY_ACTIVE_TRANSIT_TOKEN_FILE=/run/toard-secrets/vault-active-token
# TOARD_KEY_MIGRATION_PROVIDER=vault-transit
# TOARD_KEY_MIGRATION_TRANSIT_ADDRESS=https://vault.example.com:8200
# TOARD_KEY_MIGRATION_TRANSIT_MOUNT=transit
# TOARD_KEY_MIGRATION_TRANSIT_KEY_NAME=toard-next
# TOARD_KEY_MIGRATION_TRANSIT_AUTH_METHOD=token-file
# TOARD_KEY_MIGRATION_TRANSIT_TOKEN_FILE=/run/toard-secrets/vault-migration-token

# OpenBao Transit — token 원문을 env에 넣지 않습니다. 가능하면 Kubernetes auth를 사용하세요.
# TOARD_KEY_ACTIVE_PROVIDER=openbao-transit
# TOARD_KEY_ACTIVE_TRANSIT_ADDRESS=https://openbao.example.com:8200
# TOARD_KEY_ACTIVE_TRANSIT_MOUNT=transit
# TOARD_KEY_ACTIVE_TRANSIT_KEY_NAME=toard-active
# TOARD_KEY_ACTIVE_TRANSIT_AUTH_METHOD=token-file
# TOARD_KEY_ACTIVE_TRANSIT_TOKEN_FILE=/run/toard-secrets/openbao-active-token
# TOARD_KEY_MIGRATION_PROVIDER=openbao-transit
# TOARD_KEY_MIGRATION_TRANSIT_ADDRESS=https://openbao.example.com:8200
# TOARD_KEY_MIGRATION_TRANSIT_MOUNT=transit
# TOARD_KEY_MIGRATION_TRANSIT_KEY_NAME=toard-next
# TOARD_KEY_MIGRATION_TRANSIT_AUTH_METHOD=token-file
# TOARD_KEY_MIGRATION_TRANSIT_TOKEN_FILE=/run/toard-secrets/openbao-migration-token

# Local — 무료 self-hosted 선택지. KEK 파일은 정확히 32바이트이며 image에 COPY하지 않습니다.
# TOARD_KEY_ACTIVE_PROVIDER=local
# TOARD_KEY_ACTIVE_LOCAL_KEK_FILE=/run/toard-secrets/local-active-kek
# TOARD_KEY_MIGRATION_PROVIDER=local
# TOARD_KEY_MIGRATION_LOCAL_KEK_FILE=/run/toard-secrets/local-migration-kek

# 기존 server_v1 읽기가 남아 있을 때만 legacy KEK를 외부 secret store에서 주입합니다.
# TOARD_CONTENT_KEK_B64는 새 managed_v1 provider credential이 아니며, 데이터 이전과
# 백업 보존 기간이 끝나기 전에는 제거하지 마세요. 실제 base64 값은 이 파일에 기록하지 않습니다.
# 실제 값을 설정한 환경에서 `docker compose config` 출력에는 legacy KEK가 노출될 수 있으므로
# 해당 출력을 채팅·이슈에 공유하거나 파일로 저장하는 것을 금지합니다.
