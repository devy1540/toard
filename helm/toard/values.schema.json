{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "contentAdmin": { "$ref": "#/definitions/image" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "name", "annotations", "podLabels"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string", "maxLength": 253 },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "podLabels": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "migrate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "seedOnInstall", "backoffLimit", "ttlSecondsAfterFinished", "databaseSecret", "serviceAccount"],
      "properties": {
        "enabled": { "type": "boolean" },
        "seedOnInstall": { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0, "maximum": 10 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0, "maximum": 604800 },
        "databaseSecret": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "key"],
          "properties": {
            "name": { "type": "string", "pattern": "^$|^[a-z0-9](?:[-a-z0-9.]*[a-z0-9])?$", "maxLength": 253 },
            "key": { "type": "string", "pattern": "^[-._A-Za-z0-9]+$", "maxLength": 253 }
          }
        },
        "serviceAccount": {
          "type": "object",
          "additionalProperties": false,
          "required": ["create", "name"],
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string", "maxLength": 253 }
          }
        }
      }
    },
    "encryption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "cacheTtlSeconds", "active", "migration", "workloadIdentity", "cost", "secretMounts"],
      "properties": {
        "provider": { "$ref": "#/definitions/provider" },
        "cacheTtlSeconds": { "type": "integer", "minimum": 300, "maximum": 3600 },
        "active": { "$ref": "#/definitions/activeProfiles" },
        "migration": { "$ref": "#/definitions/migrationProfiles" },
        "workloadIdentity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["aws", "gcp", "azure"],
          "properties": {
            "aws": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "roleArn": { "type": "string" },
                "roleSessionName": { "type": "string" },
                "webIdentityTokenFile": { "$ref": "#/definitions/absolutePathOrEmpty" }
              }
            },
            "gcp": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "applicationCredentials": { "$ref": "#/definitions/absolutePathOrEmpty" }
              }
            },
            "azure": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "clientId": { "type": "string" },
                "tenantId": { "type": "string" },
                "federatedTokenFile": { "$ref": "#/definitions/absolutePathOrEmpty" }
              }
            }
          }
        },
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "required": ["per10000Usd", "monthlyKeyUsd"],
          "properties": {
            "per10000Usd": { "$ref": "#/definitions/decimalOrEmpty" },
            "monthlyKeyUsd": { "$ref": "#/definitions/decimalOrEmpty" }
          }
        },
        "secretMounts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/secretMount" }
        }
      }
    },
    "contentAdmin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "command"],
      "properties": {
        "enabled": { "type": "boolean" },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "definitions": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "provider": {
      "enum": ["", "local", "aws-kms", "gcp-kms", "azure-key-vault", "vault-transit", "openbao-transit"]
    },
    "absolutePathOrEmpty": {
      "type": "string",
      "pattern": "^(|/[^\\n\\r]*)$"
    },
    "decimalOrEmpty": {
      "type": "string",
      "pattern": "^(|(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?)$"
    },
    "localProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kekFile"],
      "properties": { "kekFile": { "$ref": "#/definitions/absolutePathOrEmpty" } }
    },
    "awsProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyArn", "region"],
      "properties": {
        "keyArn": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "minLength": 1 }
      }
    },
    "gcpProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyName"],
      "properties": {
        "keyName": { "type": "string", "minLength": 1 },
        "apiEndpoint": { "type": "string", "minLength": 1 }
      }
    },
    "azureProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "credentialMode"],
      "properties": {
        "keyId": { "type": "string", "minLength": 1 },
        "credentialMode": { "enum": ["managed-identity", "workload-identity"] },
        "managedIdentityClientId": { "type": "string", "minLength": 1 }
      }
    },
    "transitProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["address", "mount", "keyName", "authMethod"],
      "properties": {
        "address": { "type": "string", "minLength": 1 },
        "mount": { "type": "string", "minLength": 1 },
        "keyName": { "type": "string", "minLength": 1 },
        "authMethod": { "enum": ["token-file", "kubernetes", "approle", "static-token"] },
        "namespace": { "type": "string", "minLength": 1 },
        "tokenFile": { "$ref": "#/definitions/absolutePathOrEmpty" },
        "kubernetesRole": { "type": "string", "minLength": 1 },
        "kubernetesJwtFile": { "$ref": "#/definitions/absolutePathOrEmpty" },
        "approleRoleIdFile": { "$ref": "#/definitions/absolutePathOrEmpty" },
        "approleSecretIdFile": { "$ref": "#/definitions/absolutePathOrEmpty" }
      }
    },
    "activeProfiles": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 1,
      "properties": {
        "local": { "$ref": "#/definitions/localProfile" },
        "aws": { "$ref": "#/definitions/awsProfile" },
        "gcp": { "$ref": "#/definitions/gcpProfile" },
        "azure": { "$ref": "#/definitions/azureProfile" },
        "vault": { "$ref": "#/definitions/transitProfile" },
        "openbao": { "$ref": "#/definitions/transitProfile" }
      }
    },
    "migrationProfiles": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 2,
      "properties": {
        "provider": { "$ref": "#/definitions/provider" },
        "local": { "$ref": "#/definitions/localProfile" },
        "aws": { "$ref": "#/definitions/awsProfile" },
        "gcp": { "$ref": "#/definitions/gcpProfile" },
        "azure": { "$ref": "#/definitions/azureProfile" },
        "vault": { "$ref": "#/definitions/transitProfile" },
        "openbao": { "$ref": "#/definitions/transitProfile" }
      }
    },
    "secretMount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "secretName", "mountPath", "items"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9](?:[-a-z0-9]*[a-z0-9])?$", "maxLength": 63 },
        "secretName": { "type": "string", "pattern": "^[a-z0-9](?:[-a-z0-9.]*[a-z0-9])?$", "maxLength": 253 },
        "mountPath": {
          "type": "string",
          "pattern": "^/[A-Za-z0-9][A-Za-z0-9._-]*(/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "path"],
            "properties": {
              "key": { "type": "string", "pattern": "^[-._A-Za-z0-9]+$", "maxLength": 253 },
              "path": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
              }
            }
          }
        }
      }
    }
  }
}
