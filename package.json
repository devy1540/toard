{
  "name": "toard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "경량 멀티 프로바이더 AI 사용량 대시보드",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @toard/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test && pnpm test:migrations",
    "test:migrations": "TSX_TSCONFIG_PATH=apps/web/tsconfig.json node --import tsx --test scripts/pricing-revisions-migration.integration.test.ts scripts/pricing-auto-recovery-migration.integration.test.ts scripts/historical-pricing-migration.integration.test.ts scripts/rollup-coordinator-migration.integration.test.ts scripts/e2ee-content-migration.integration.test.ts scripts/e2ee-legacy-migration.integration.test.ts scripts/e2ee-legacy-retirement-migration.integration.test.ts scripts/tool-deployment-migration.integration.test.ts",
    "lint": "pnpm -r lint",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "migrate": "node-pg-migrate -j sql -m migrations -d DATABASE_URL up",
    "migrate:down": "node-pg-migrate -j sql -m migrations -d DATABASE_URL down",
    "seed": "tsx scripts/seed.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:dashboard-demo": "tsx scripts/seed-dashboard-demo.ts",
    "rollup:activate-timezones": "tsx scripts/activate-timezone-rollups.ts",
    "benchmark:dashboard-http": "tsx scripts/benchmark-dashboard-release.ts",
    "benchmark:dashboard-http:inner": "tsx scripts/benchmark-dashboard-http.ts",
    "benchmark:dashboard-http:diagnostic": "tsx scripts/benchmark-dashboard-http.ts",
    "benchmark:rollup:micro": "tsx scripts/benchmark-timezone-rollup.ts",
    "verify:pricing-auto-recovery": "tsx scripts/verify-pricing-auto-recovery.ts",
    "verify:historical-pricing": "tsx scripts/verify-historical-pricing-recovery.ts",
    "test:benchmark-dashboard-http": "node --import tsx --test scripts/benchmark-dashboard-http.test.ts scripts/benchmark-dashboard-release.test.ts",
    "test:benchmark-dashboard-signal": "RUN_DOCKER_SIGNAL_INTEGRATION=1 node --import tsx --test scripts/benchmark-dashboard-release-signal.integration.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "node-pg-migrate": "^7.9.0",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
